# Server Configuration
PORT=5000

# Database Configuration
DATABASE_URL="postgresql://username:password@host:port/database"

# JWT Configuration
JWT_SECRET="your_jwt_secret_key_minimum_32_characters_required"
JWT_REFRESH_SECRET="your_refresh_token_secret_key_minimum_32_characters_required"

# Email Configuration
USER_EMAIL="your_email@example.com"
PASS_EMAIL="your_email_app_password"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Facebook OAuth Configuration
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Nepal Payment Gateway (NPG) Configuration
NPG_BASE_URL="https://merchantsandbox.nepalpayment.com"
NPG_API_USERNAME="your_npg_username"
NPG_API_PASSWORD="your_npg_password"
NPG_MERCHANT_ID="your_merchant_id"
NPG_SECRET_KEY="your_npg_secret_key"
NPG_ACCESS_CODE="your_access_code"

# Nepal Payment Gateway (NPX) Configuration
# Used for payment processing via Nepal Payment Gateway API
NPX_MERCHANT_ID="545"
NPX_MERCHANT_NAME="your_merchant_name"
NPX_API_USERNAME="your_npx_api_username"
NPX_API_PASSWORD="your_npx_api_password"
NPX_SECRET_KEY="your_npx_secret_key"
NPX_BASE_URL="https://apigateway.nepalpayment.com"
NPX_GATEWAY_URL="https://gateway.nepalpayment.com/"

# Frontend/Backend URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:5000"
PRODUCTION_FRONTEND_URL="https://your-production-frontend.com"
PRODUCTION_BACKEND_URL="https://your-production-backend.com"

# eSewa Payment Configuration
ESEWA_MERCHANT="your_esewa_merchant_code"
SECRET_KEY="your_esewa_secret_key"
ESEWA_PAYMENT_URL="https://epay.esewa.com.np/api/epay/main/v2/form"
